# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# Bot's username WITHOUT the @ — required to build PM deep-link buttons
BOT_USERNAME=YourHandCricketBot

# Two Telegram numeric user IDs that get full Owner powers everywhere
OWNER_ID_1=111111111
OWNER_ID_2=222222222

# Where JSON data files (media_assets.json, player_stats.json) are stored
DATA_DIR=data
